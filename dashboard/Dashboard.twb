      <aliases enabled='yes' />
      <column caption='Total Revenue' datatype='integer' name='[Calculation_0195995790295040]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='Sum([revenue])' />
      </column>
      <column caption='Total Prescription' datatype='integer' name='[Calculation_0195995791708161]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([prescriptions])' />
      </column>
      <column caption='Average Achievement %' datatype='real' name='[Calculation_0195995792908290]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([achieved_pct])' />
      </column>
      <column caption='Average ROI' datatype='real' name='[Calculation_0195995794702339]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue]) / SUM([marketing_spend])' />
      </column>
      <column caption='Region Revenue' datatype='real' name='[Calculation_0195995804663812]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue]) / TOTAL(SUM([revenue])) * 100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
